{
  "name": "biggy",
  "version": "0.1.0",
  "private": true,
  "description": "Biggy — Telegram bot for data-driven football accumulators",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:migrate": "tsx src/db/migrate.ts",
