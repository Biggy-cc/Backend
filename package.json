    "db:migrate-to-d1": "tsx scripts/migrate-to-d1.ts",
    "txline:activate": "tsx scripts/activate-txline.ts",
    "test:gemini": "tsx scripts/test-gemini.ts",
    "test:llm": "tsx scripts/test-llm.ts",
    "test:openrouter": "tsx scripts/test-openrouter.ts",
    "test:gemini-grounding": "tsx scripts/test-gemini-grounding.ts",
