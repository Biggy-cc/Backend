# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=
# Optional: gemini-2.5-flash-lite has higher free-tier RPD
# GEMINI_MODEL=gemini-2.5-flash

# ─── LLM fallbacks (used when Gemini quota is exhausted) ───
# Order: Gemini → OpenRouter → Groq → odds fallback
# Groq: https://console.groq.com/keys (free tier)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter: https://openrouter.ai/keys (free :free models; 50 req/day, 1000/day after $10 credits)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# ─── Solana (mainnet) ───────────────────────────────────────
# Backend wallet: TxLINE registration + optional payment receiver
# Base58-encoded secret key (64 bytes) or path to keypair JSON
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet that receives user USDC subscriptions (can match backend wallet)
USDC_RECEIVER_WALLET=

# Mainnet USDC mint (do not change unless you know why)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── TxLINE (mainnet) ───────────────────────────────────────
TXLINE_API_ORIGIN=https://txline.txodds.com
# 1 = 60s delay (free) | 12 = real-time World Cup (free on mainnet)
TXLINE_SERVICE_LEVEL=12
# Set after running: npm run txline:activate
TXLINE_API_TOKEN=

# ─── Biggy product ──────────────────────────────────────────
TRIAL_PICKS=2
MONTHLY_USDC=5
YEARLY_USDC=54
# Cron: daily morning drop (UTC) — adjust for World Cup timezone
DAILY_CRON=0 8 * * *
# Re-check lines/news and update picks if data shifted (noon + 6pm UTC)
PICKS_REFRESH_CRON=0 12,18 * * *

# Frontend checkout page (recommended for Telegram payments)
# When set, bot sends user here instead of wallet deep links
# PAYMENT_WEB_URL=https://biggy.cc/pay

# ─── App ────────────────────────────────────────────────────
# Local SQLite file (always used as migration source; default backend)
DATABASE_PATH=./data/biggy.db
# Set to d1 after migrating data with: npm run db:migrate-to-d1
DATABASE_BACKEND=sqlite

# Cloudflare D1 (only needed when DATABASE_BACKEND=d1)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

NODE_ENV=development
