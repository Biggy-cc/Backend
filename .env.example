# ─── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Google Gemini ──────────────────────────────────────────
GEMINI_API_KEY=
# Optional: gemini-2.5-flash-lite has higher free-tier RPD
# GEMINI_MODEL=gemini-2.5-flash

# ─── LLM fallbacks (used when Gemini quota is exhausted) ───
# Order: Gemini → OpenRouter → Groq → odds fallback
# Groq: https://console.groq.com/keys (free tier)
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter: https://openrouter.ai/keys (free :free models; 50 req/day, 1000/day after $10 credits)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

# ─── Solana (mainnet) ───────────────────────────────────────
# Backend wallet: TxLINE registration + optional payment receiver
# Base58-encoded secret key (64 bytes) or path to keypair JSON
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# For production, use a dedicated provider (Helius, QuickNode, etc.) — browser cannot call public RPC directly.
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Wallet that receives user USDC subscriptions (can match backend wallet)
USDC_RECEIVER_WALLET=

# Mainnet USDC mint (do not change unless you know why)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ─── TxLINE (mainnet) ───────────────────────────────────────
TXLINE_API_ORIGIN=https://txline.txodds.com
# 1 = 60s delay (free) | 12 = real-time World Cup (free on mainnet)
TXLINE_SERVICE_LEVEL=12
# Set after running: npm run txline:activate
TXLINE_API_TOKEN=

# ─── Highlightly (live scores / events — free 100 req/day) ──
# https://highlightly.net — live pitch tracker in Telegram
HIGHLIGHTLY_API_KEY=

# ─── Biggy product ──────────────────────────────────────────
TRIAL_PICKS=2
MONTHLY_USDC=9
YEARLY_USDC=79

# Live payment test for one Telegram user (remove after verifying checkout)
# PAYMENT_TEST_TELEGRAM_ID=5309840190
# PAYMENT_TEST_USDC=1

# Ping this Telegram user when someone subscribes (defaults to Dracklyn; set 0 to disable)
# SUBSCRIPTION_NOTIFY_TELEGRAM_ID=5309840190
# Cron: daily morning drop (UTC) — adjust for World Cup timezone
DAILY_CRON=0 8 * * *
# Re-check lines/news and update picks if data shifted (noon + 6pm UTC)
PICKS_REFRESH_CRON=0 12,18 * * *
# Decimal odds delta that triggers a slip version bump on refresh (default 0.03)
# ODDS_MOVE_THRESHOLD=0.03
# TxLINE historical replay for track-record grading (opt-in — many API calls)
# TXLINE_REPLAY_GRADING=1

# Frontend checkout page (recommended for Telegram payments)
# When set, bot sends user here instead of wallet deep links
# Site checkout page (bot sends users here instead of wallet deep links)
# Local: http://127.0.0.1/pay
# Production: https://biggy.cc/pay
# PAYMENT_WEB_URL=http://127.0.0.1/pay

# Landing page checkout (same process as bot)
FIXTURES_API_PORT=8787
# Set in @BotFather → /setdomain for Telegram Login Widget (e.g. biggy.cc)

# Future: Gemini-backed freeform chat (keyword routing used when off)
# CONVERSATIONAL_CHAT=1

# Optional PNG tier badges in Telegram (SVG cannot render in bot text)
# TIER_ICON_HIT_URL=https://biggy.cc/brand/hit-icon.png
# TIER_ICON_AIM_URL=https://biggy.cc/brand/aim-icon.png
# TIER_ICON_GOBIG_URL=https://biggy.cc/brand/go-big-icon.png

# Telegram banners (generate with: cd Frontend && npm run telegram:banners)
# TELEGRAM_WELCOME_BANNER_URL=https://biggy.cc/telegram/welcome-banner.mp4
# TELEGRAM_SLIP_HIT_BANNER_URL=https://biggy.cc/telegram/slip-hit.mp4
# TELEGRAM_SLIP_AIM_BANNER_URL=https://biggy.cc/telegram/slip-aim.mp4
# TELEGRAM_SLIP_GOBIG_BANNER_URL=https://biggy.cc/telegram/slip-gobig.mp4

# ─── App ────────────────────────────────────────────────────
# Local SQLite file (always used as migration source; default backend)
# Railway: mount a volume at ./data so picks survive redeploys
DATABASE_PATH=./data/biggy.db
# Set to d1 after migrating data with: npm run db:migrate-to-d1
DATABASE_BACKEND=sqlite

# Cloudflare D1 (only needed when DATABASE_BACKEND=d1)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

NODE_ENV=development
